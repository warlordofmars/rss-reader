{
  "permissions": {
    "allow": [
      "WebFetch(domain:support.google.com)",
      "WebFetch(domain:developers.google.com)",
      "Bash(python3 -c \"import secrets; print\\(secrets.token_hex\\(32\\)\\)\")",
      "Bash(uv run:*)",
      "Bash(npx vitest:*)",
      "Bash(npm test:*)",
      "Bash(uv add:*)",
      "Bash(jq -e '.hooks.PostToolUse[] | select\\(.matcher == \"\"Write|Edit\"\"\\) | .hooks[] | select\\(.type == \"\"command\"\"\\) | .command' /Users/john/Projects/rss-reader/.claude/settings.json)",
      "Bash(gh auth:*)",
      "Bash(git init:*)",
      "Bash(git add:*)",
      "Bash(ls /Users/john/Projects/rss-reader/backend/package*.json)",
      "Bash(rm -rf /Users/john/Projects/rss-reader/frontend/.git)",
      "Bash(git rm:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); if echo \"$f\" | grep -q '/rss-reader/backend/' && ! echo \"$f\" | grep -qE '/rss-reader/backend/(tests/|\\.venv/)'; then cd /Users/john/Projects/rss-reader/backend && uv run pytest tests/ -q; elif echo \"$f\" | grep -q '/rss-reader/frontend/src/'; then cd /Users/john/Projects/rss-reader/frontend && npm test; fi",
            "timeout": 120,
            "statusMessage": "Running tests..."
          }
        ]
      }
    ]
  }
}
