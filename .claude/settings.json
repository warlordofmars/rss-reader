{
  "permissions": {
    "allow": [
      "WebFetch(domain:support.google.com)",
      "WebFetch(domain:developers.google.com)",
      "Bash(python3 -c \"import secrets; print\\(secrets.token_hex\\(32\\)\\)\")",
      "Bash(uv run:*)",
      "Bash(npx vitest:*)",
      "Bash(npm test:*)",
      "Bash(uv add:*)",
      "Bash(jq -e '.hooks.PostToolUse[] | select\\(.matcher == \"\"Write|Edit\"\"\\) | .hooks[] | select\\(.type == \"\"command\"\"\\) | .command' /Users/john/Projects/rss-reader/.claude/settings.json)",
      "Bash(gh auth:*)",
      "Bash(git init:*)",
      "Bash(git add:*)",
      "Bash(ls /Users/john/Projects/rss-reader/backend/package*.json)",
      "Bash(rm -rf /Users/john/Projects/rss-reader/frontend/.git)",
      "Bash(git rm:*)",
      "Bash(npm run:*)",
      "Bash(npm audit:*)",
      "Bash(uv tree:*)",
      "Bash(git commit:*)",
      "Bash(gh run:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(cdk --version)",
      "Bash(uv python:*)",
      "Bash(ls /Users/john/Projects/rss-reader/backend/.env*)",
      "Bash(ls /Users/john/Projects/rss-reader/frontend/src/components/*.test.*)",
      "Bash(JSII_SILENCE_WARNING_UNTESTED_NODE_VERSION=1 uv run cdk synth --no-staging)",
      "Bash(echo \"EXIT: $?\")",
      "Bash(JSII_SILENCE_WARNING_UNTESTED_NODE_VERSION=1 uv run cdk synth --no-staging --output cdk.out2)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); if echo \"$f\" | grep -q '/rss-reader/backend/' && ! echo \"$f\" | grep -qE '/rss-reader/backend/(\\.venv/)'; then cd /Users/john/Projects/rss-reader/backend && uv run ruff check . && uv run pytest tests/ -q; elif echo \"$f\" | grep -q '/rss-reader/frontend/' && ! echo \"$f\" | grep -qE '/rss-reader/frontend/(node_modules|coverage|dist)/'; then cd /Users/john/Projects/rss-reader/frontend && npm run lint && npm test; fi",
            "timeout": 120,
            "statusMessage": "Running tests..."
          }
        ]
      }
    ]
  }
}
